<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReviewIT.MainPage"
             Title="Home Page">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <Label
                Text="Hello [User], Welcome to ReviewIT!"
                x:Name="getUser"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                VerticalTextAlignment="Center"/>

            <Label
                x:Name="emptyQA"
                FontSize="18"
                Text="It looks your new here. Browse or Create a new set of questionnaires"
                HorizontalTextAlignment="Center"
                VerticalTextAlignment="Center"/>

            <Button
                Text="Create Questionnaire"
                Clicked="GoToCreateQuestions"/>

            <Button
                Text="My Library"
                Clicked="GoToYourLibrary"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
